# HostPanel Server Configuration
# Copy this file to .env and fill in your values.
#
# Only bootstrap values live here — things the server needs before the DB
# is reachable, or that change the install layout. Application config
# (SMTP, Stripe, PayPal, Cloudflare, company info, 2FA enforcement, etc.)
# is edited from the panel itself at /settings and stored in the SQLite
# settings table. Don't add those keys here; the server no longer reads
# them at request time.

PORT=3001
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Fallback admin used when the admin_users table is empty. After the
# first login through the panel you can rotate the password from
# /admin-users instead of editing this hash.
ADMIN_USER=admin
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
ADMIN_PASS_HASH=$2b$12$examplehashhere

# ── CORS / payment redirects ─────────────────────────────────
# CORS allowlist origin (boot-time) and the host used to build Stripe /
# PayPal success URLs. install.sh fills this in from the hostname prompt.
CLIENT_URL=http://localhost:5173

# ── File paths ────────────────────────────────────────────────
FILES_BASE_DIR=/var/www
WEBROOT=/var/www

# ── Web server ────────────────────────────────────────────────
# Apache (RHEL/Rocky/AlmaLinux)
VHOST_DIR=/etc/httpd/conf.d
# Nginx (if using Nginx vhost manager)
NGINX_DIR=/etc/nginx/sites-available
NGINX_EN=/etc/nginx/sites-enabled

# ── DNS (BIND/named) ─────────────────────────────────────────
NAMED_DIR=/var/named
NAMED_CONF=/etc/named.conf

# ── Email (Postfix + Dovecot) ─────────────────────────────────
VMAIL_DIR=/etc/postfix/virtual
MAIL_PASSWD=/etc/dovecot/users

# ── FTP (vsftpd) ─────────────────────────────────────────────
FTP_USER_DIR=/etc/vsftpd/users

# ── Database (MariaDB / MySQL) ────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_ROOT_USER=root
DB_ROOT_PASS=
