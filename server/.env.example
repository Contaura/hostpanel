# HostPanel Server Configuration
PORT=3001
NODE_ENV=development

# IMPORTANT: Change these before deploying
JWT_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_USER=admin
# Generate hash with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
ADMIN_PASS_HASH=$2b$12$examplehashhere

# Client origin for CORS
CLIENT_URL=http://localhost:5173

# File manager base directory
FILES_BASE_DIR=/var/www

# Web server vhost directory (Apache on RHEL/Rocky)
VHOST_DIR=/etc/httpd/conf.d
WEBROOT=/var/www

# DNS (BIND/named)
NAMED_DIR=/var/named
NAMED_CONF=/etc/named.conf

# Email (Postfix + Dovecot)
VMAIL_DIR=/etc/postfix/virtual
MAIL_PASSWD=/etc/dovecot/users

# FTP (vsftpd)
FTP_USER_DIR=/etc/vsftpd/users

# Database (MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_ROOT_USER=root
DB_ROOT_PASS=
