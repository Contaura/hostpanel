# HostPanel Server Configuration
# Copy this file to .env and fill in your values

PORT=3001
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Fallback admin credentials (used if admin_users table is empty)
ADMIN_USER=admin
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
ADMIN_PASS_HASH=$2b$12$examplehashhere

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── File paths ────────────────────────────────────────────────
FILES_BASE_DIR=/var/www
WEBROOT=/var/www

# ── Web server ────────────────────────────────────────────────
# Apache (RHEL/Rocky/AlmaLinux)
VHOST_DIR=/etc/httpd/conf.d
# Nginx (if using Nginx vhost manager)
NGINX_DIR=/etc/nginx/sites-available
NGINX_EN=/etc/nginx/sites-enabled

# ── DNS (BIND/named) ─────────────────────────────────────────
NAMED_DIR=/var/named
NAMED_CONF=/etc/named.conf

# ── Email (Postfix + Dovecot) ─────────────────────────────────
VMAIL_DIR=/etc/postfix/virtual
MAIL_PASSWD=/etc/dovecot/users

# ── FTP (vsftpd) ─────────────────────────────────────────────
FTP_USER_DIR=/etc/vsftpd/users

# ── Database (MariaDB / MySQL) ────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_ROOT_USER=root
DB_ROOT_PASS=

# ── Stripe ────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PayPal ────────────────────────────────────────────────────
# Get credentials from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# ── SMTP (used for invoice emails and notifications) ──────────
# Can also be configured via Settings page in the admin UI
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
